spring.application.name=test-telecome
server.port=8080
server.address=0.0.0.0

# ═══════════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════════
spring.datasource.url=jdbc:mysql://localhost:3306/telecom_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
spring.datasource.username=changeme
spring.datasource.password=changeme
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

# Connection Pool
spring.datasource.hikari.maximum-pool-size=30
spring.datasource.hikari.minimum-idle=10
spring.datasource.hikari.connection-timeout=60000

# ═══════════════════════════════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════════════════════════════
spring.web.cors.allowed-origins=http://localhost:3000,http://127.0.0.1:3000

# ═══════════════════════════════════════════════════════════════════
# Containerlab Configuration
# ═══════════════════════════════════════════════════════════════════
clab.container.prefix=clab-telecom-supervision-
clab.topology.name=telecom-supervision

# ═══════════════════════════════════════════════════════════════════
# SSH (JSch)
# ═══════════════════════════════════════════════════════════════════
ssh.default.username=changeme
ssh.default.password=changeme
ssh.default.port=22
ssh.connect.timeout=5000
ssh.command.timeout=10000

# ═══════════════════════════════════════════════════════════════════
# AI Engine
# ═══════════════════════════════════════════════════════════════════
ai.engine.url=http://localhost:5000

# ═══════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════
logging.level.com.example.demo=INFO
logging.level.org.springframework.web=WARN
logging.level.org.hibernate=WARN
